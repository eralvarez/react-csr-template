    "react-router": "7.14.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.14.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.3",
    "serve": "^14.2.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
